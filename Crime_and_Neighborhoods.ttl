#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000066
<http://purl.obolibrary.org/obo/BFO_0000066> rdfs:domain :CrimeIncident ;
                                             rdfs:range :Neighborhood .


#################################################################
#    Data properties
#################################################################

###  https://ian-reinl.github.io/mpls-crime-ontology/ontology.ttl#address
:address rdf:type owl:DatatypeProperty ;
         rdfs:domain :CrimeIncident ;
         rdfs:range xsd:string .


###  https://ian-reinl.github.io/mpls-crime-ontology/ontology.ttl#areaSize
:areaSize rdf:type owl:DatatypeProperty ;
          rdfs:domain :Neighborhood ;
          rdfs:range xsd:decimal .


###  https://ian-reinl.github.io/mpls-crime-ontology/ontology.ttl#caseNumber
:caseNumber rdf:type owl:DatatypeProperty ;
            rdfs:domain :CrimeIncident ;
            rdfs:range xsd:string .


###  https://ian-reinl.github.io/mpls-crime-ontology/ontology.ttl#neighborhoodName
:neighborhoodName rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Neighborhood ;
                  rdfs:range xsd:string .


###  https://ian-reinl.github.io/mpls-crime-ontology/ontology.ttl#neighborhoodNumber
:neighborhoodNumber rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Neighborhood ;
                    rdfs:range xsd:integer .


###  https://ian-reinl.github.io/mpls-crime-ontology/ontology.ttl#occurredDate
:occurredDate rdf:type owl:DatatypeProperty ;
              rdfs:domain :CrimeIncident ;
              rdfs:range xsd:dateTime .


###  https://ian-reinl.github.io/mpls-crime-ontology/ontology.ttl#offense
:offense rdf:type owl:DatatypeProperty ;
         rdfs:domain :CrimeIncident ;
         rdfs:range xsd:string .


###  https://ian-reinl.github.io/mpls-crime-ontology/ontology.ttl#precinct
:precinct rdf:type owl:DatatypeProperty ;
          rdfs:domain :CrimeIncident ;
          rdfs:range xsd:integer .


###  https://ian-reinl.github.io/mpls-crime-ontology/ontology.ttl#reportedDate
:reportedDate rdf:type owl:DatatypeProperty ;
              rdfs:domain :CrimeIncident ;
              rdfs:range xsd:dateTime .


###  https://ian-reinl.github.io/mpls-crime-ontology/ontology.ttl#ward
:ward rdf:type owl:DatatypeProperty ;
      rdfs:domain :CrimeIncident ;
      rdfs:range xsd:integer .


#################################################################
#    Classes
#################################################################

###  https://ian-reinl.github.io/mpls-crime-ontology/ontology.ttl#CrimeIncident
:CrimeIncident rdf:type owl:Class ;
               rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ;
               rdfs:comment "An intentional act in which at least one agent plays a causative role, occurring at a location and time, and classified by type according to a reporting standard." ;
               rdfs:label "Crime Incident" .


###  https://ian-reinl.github.io/mpls-crime-ontology/ontology.ttl#MinneapolisNeighborhood
:MinneapolisNeighborhood rdf:type owl:Class ;
                         rdfs:subClassOf :Neighborhood ;
                         rdfs:comment "A neighborhood whose boundaries are defined by the City of Minneapolis and the Minneapolis Park and Recreation Board." ;
                         rdfs:label "Minneapolis Neighborhood" .


###  https://ian-reinl.github.io/mpls-crime-ontology/ontology.ttl#Neighborhood
:Neighborhood rdf:type owl:Class ;
              rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000029> ;
              rdfs:comment "A fiat geographic region defined by administrative boundaries within a populated place." ;
              rdfs:label "Neighborhood" .


