<https://ian-reinl.github.io/mpls-crime-ontology/ontology.ttl> a owl:Ontology ;
    owl:imports <http://purl.obolibrary.org/obo/bfo/2020/bfo-core.owl> .

:MinneapolisNeighborhood a owl:Class ;
    rdfs:label "Minneapolis Neighborhood" ;
    rdfs:comment "A neighborhood whose boundaries are defined by the City of Minneapolis and the Minneapolis Park and Recreation Board." ;
    rdfs:subClassOf :Neighborhood .

:address a owl:DatatypeProperty ;
    rdfs:domain :CrimeIncident ;
    rdfs:range xsd:string .

:areaSize a owl:DatatypeProperty ;
    rdfs:domain :Neighborhood ;
    rdfs:range xsd:decimal .

:caseNumber a owl:DatatypeProperty ;
    rdfs:domain :CrimeIncident ;
    rdfs:range xsd:string .

:neighborhoodName a owl:DatatypeProperty ;
    rdfs:domain :Neighborhood ;
    rdfs:range xsd:string .

:neighborhoodNumber a owl:DatatypeProperty ;
    rdfs:domain :Neighborhood ;
    rdfs:range xsd:integer .

:occurredDate a owl:DatatypeProperty ;
    rdfs:domain :CrimeIncident ;
    rdfs:range xsd:dateTime .

:offense a owl:DatatypeProperty ;
    rdfs:domain :CrimeIncident ;
    rdfs:range xsd:string .

:precinct a owl:DatatypeProperty ;
    rdfs:domain :CrimeIncident ;
    rdfs:range xsd:integer .

:reportedDate a owl:DatatypeProperty ;
    rdfs:domain :CrimeIncident ;
    rdfs:range xsd:dateTime .

:ward a owl:DatatypeProperty ;
    rdfs:domain :CrimeIncident ;
    rdfs:range xsd:integer .

:Neighborhood a owl:Class ;
    rdfs:label "Neighborhood" ;
    rdfs:comment "A fiat geographic region defined by administrative boundaries within a populated place." ;
    rdfs:subClassOf bfo:BFO_0000029 .

:CrimeIncident a owl:Class ;
    rdfs:label "Crime Incident" ;
    rdfs:comment "An intentional act in which at least one agent plays a causative role, occurring at a location and time, and classified by type according to a reporting standard." ;
    rdfs:subClassOf bfo:BFO_0000015 .

